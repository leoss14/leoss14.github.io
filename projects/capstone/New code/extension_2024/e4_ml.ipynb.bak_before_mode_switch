    "    res = train_models(eng, feature_list=FEATURES_STRUCTURAL)\n",
    "    if res is None:\n",
    "        print(f'  imp {imp_id}: empty panel after dropna')\n",
    "        continue\n",
    "    for name in res['models']:\n",
    "        scores = res['fold_scores'][name]\n",
    "        oof = res['oof'][name]\n",
    "        mask = ~np.isnan(oof)\n",
    "        struct_results.append({\n",
    "            'imputation': imp_id,\n",
