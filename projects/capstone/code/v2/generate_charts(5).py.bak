)
save(fig07, "07_lasso_ridge_en_coefficients.html")


# ── CHART 08: RF Feature Importance ──────────────────────────────────────────
print("08 RF feature importance …")

rf_show = imp_show.sort_values("RF", ascending=True).copy()
fig08 = go.Figure(go.Bar(
