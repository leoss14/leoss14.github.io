# Normalised absolute coefficients (min-max 0-1), excluding lagged ECI
cons_df = imp_show.sort_values("avg", ascending=False).head(15).iloc[::-1].copy()
lin_models_names = ["LASSO", "Ridge", "Elastic Net"]
